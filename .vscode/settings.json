{
  "cmake.useCMakePresets": "never",
  "cmake.configureOnOpen": true,
  "cmake.buildBeforeRun": true,
  "cmake.generator": "Ninja",
  "cmake.buildDirectory": "${workspaceFolder}/build",

  "cmake.configureSettings": {
    "CMAKE_BUILD_TYPE": "Debug",
    "CMAKE_EXPORT_COMPILE_COMMANDS": true,

    // TODO: change ONLY the QT6 ROOT line
    // MAC: modify the username to match your username and ensure the path matches your Qt installation.
    "Qt6_ROOT": "/Users/mneal126/Qt/6.11.0/macos"
    //WINDOWS: comment out the MAC line and uncomment the WINDOWS line, changing the path to match your Qt installation
    //"Qt6_ROOT": "C:/Qt/6.11.0/msvc2022_64"
  },

  "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",

  "editor.inlineSuggest.enabled": false,
  "editor.suggest.preview": false,
  "editor.suggestOnTriggerCharacters": true,
  "github.copilot.enabled": false,
  "github.copilot.inlineSuggest.enable": false
}